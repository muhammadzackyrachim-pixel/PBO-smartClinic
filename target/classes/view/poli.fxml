<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PoliController"
            stylesheets="@style.css">
    <top>
        <VBox spacing="10" styleClass="top-panel">
            <Label text="DATA POLIKLINIK"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>
            <HBox spacing="10" alignment="CENTER">
                <Button text="➕ Tambah"
                        onAction="#handleTambah"
                        styleClass="btn-tambah"/>
                <Button text="✏️ Edit"
                        onAction="#handleEdit"
                        styleClass="btn-edit"/>
                <Button text="🗑️ Hapus"
                        onAction="#handleHapus"
                        styleClass="btn-hapus"/>
                <Button text="🔄 Refresh"
                        onAction="#loadData"
                        styleClass="btn-refresh"/>
                <Button text="⬅️ Kembali"
                        onAction="#handleBack"
                        styleClass="btn-close"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="15" styleClass="main-panel" VBox.vgrow="ALWAYS">
            <TableView fx:id="tablePoli"
                       VBox.vgrow="ALWAYS"
                       maxWidth="Infinity">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="colNama" text="Nama Poli" prefWidth="300"/>
                    <TableColumn fx:id="colKeterangan" text="Keterangan" prefWidth="500"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>
</BorderPane>
