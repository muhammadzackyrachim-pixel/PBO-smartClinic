<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.RiwayatPemeriksaanController" stylesheets="@style.css">
<top>
    <VBox spacing="10" styleClass="top-panel">
        <Label text="RIWAYAT PEMERIKSAAN PASIEN" styleClass="title" maxWidth="Infinity" alignment="CENTER"/>
        <HBox spacing="10" alignment="CENTER">
            <Label text="Pilih Pasien:" styleClass="label-subtitle"/>
            <ComboBox fx:id="cbPasien" prefWidth="250" promptText="-- Pilih Pasien --" onAction="#handlePilihPasien"/>
            <Button text="🔄 Refresh" onAction="#loadData" styleClass="btn-refresh"/>
            <Button text="⬅️ Kembali" onAction="#handleBack" styleClass="btn-close"/>
        </HBox>
    </VBox>
</top>
<center>
    <VBox spacing="15" styleClass="main-panel" VBox.vgrow="ALWAYS">
        <TableView fx:id="tableRiwayat" VBox.vgrow="ALWAYS" maxWidth="Infinity">
            <columns>
                <TableColumn fx:id="colTanggal" text="Tanggal" prefWidth="120"/>
                <TableColumn fx:id="colTensi" text="Tensi" prefWidth="100"/>
                <TableColumn fx:id="colSuhu" text="Suhu" prefWidth="80"/>
                <TableColumn fx:id="colBB" text="BB" prefWidth="80"/>
                <TableColumn fx:id="colTB" text="TB" prefWidth="80"/>
                <TableColumn fx:id="colCatatan" text="Catatan Pemeriksaan" prefWidth="400"/>
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>
    </VBox>
</center>
</BorderPane>