<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.RiwayatPemeriksaanController" stylesheets="@style.css">
<top>
    <VBox spacing="10" styleClass="top-panel">
        <Label text="RIWAYAT PEMERIKSAAN PASIEN" styleClass="title" maxWidth="Infinity" alignment="CENTER"/>
        <HBox spacing="10" alignment="CENTER">
            <Label text="Cari Pasien:" styleClass="label-subtitle"/>
            <TextField fx:id="txtCari" prefWidth="200" promptText="Ketik nama pasien..."/>
            <Label text="Tanggal:" styleClass="label-subtitle"/>
            <DatePicker fx:id="dpTanggal" prefWidth="150" promptText="Pilih tanggal"/>
            <Button text="✖ Reset" onAction="#handleReset" styleClass="btn-cancel"/>
        </HBox>
    </VBox>
</top>
<center>
    <VBox spacing="15" styleClass="main-panel" VBox.vgrow="ALWAYS">
        <TableView fx:id="tableRiwayat" VBox.vgrow="ALWAYS" maxWidth="Infinity">
            <columns>
                <TableColumn fx:id="colPasien" text="Nama Pasien" prefWidth="150"/>
                <TableColumn fx:id="colTanggal" text="Tanggal" prefWidth="120"/>
                <TableColumn fx:id="colTensi" text="Tensi" prefWidth="100"/>
                <TableColumn fx:id="colSuhu" text="Suhu" prefWidth="80"/>
                <TableColumn fx:id="colBB" text="BB" prefWidth="80"/>
                <TableColumn fx:id="colTB" text="TB" prefWidth="80"/>
                <TableColumn fx:id="colCatatan" text="Catatan Pemeriksaan" prefWidth="400"/>
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        </TableView>
        <HBox alignment="CENTER" spacing="15" prefHeight="50">
            <Button fx:id="btnPrev" text="◀ Sebelumnya" onAction="#handlePrevPage" style="-fx-background-color: white; -fx-text-fill: #334155; -fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;"/>
            <Label fx:id="lblHalaman" text="Halaman 1 / 1" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #334155;"/>
            <Button fx:id="btnNext" text="Selanjutnya ▶" onAction="#handleNextPage" style="-fx-background-color: white; -fx-text-fill: #334155; -fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</center>
</BorderPane>