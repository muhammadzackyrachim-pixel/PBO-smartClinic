<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DashboardController"
            stylesheets="@style.css"
            styleClass="root-dashboard">
    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
            <VBox spacing="5" alignment="TOP_CENTER" prefWidth="240" styleClass="sidebar">
                <Label text="SMART CLINIC" styleClass="logo-title"/>
                <Separator prefWidth="180"/>
                <Button text="🏠 Dashboard" styleClass="menu-btn"/>
                <Label text="MASTER DATA" styleClass="menu-group"/>
                <Button text="👨‍⚕ Pasien" styleClass="menu-btn" onAction="#openPasien"/>
                <Button text="🩺 Dokter" styleClass="menu-btn" onAction="#openDokter"/>
                <Button text="👩‍💼 Petugas" styleClass="menu-btn" onAction="#openPetugas"/>
                <Button text="💊 Obat" styleClass="menu-btn" onAction="#openObat"/>
                
                <Label text="TRANSAKSI" styleClass="menu-group"/>
                <Button text="📝 Pendaftaran" styleClass="menu-btn" onAction="#openPendaftaran"/>
                
                <!-- ✅ MENU BARU: PEMERIKSAAN DOKTER -->
                <Button text="🩺 Pemeriksaan Dokter" styleClass="menu-btn" onAction="#openPemeriksaan"/>
                
                <!-- ✅ MENU BARU: RIWAYAT PEMERIKSAAN -->
                <Button text="📜 Riwayat Periksa" styleClass="menu-btn" onAction="#openRiwayatPemeriksaan"/>
                
                <Button text="🩻 Rekam Medis" styleClass="menu-btn" onAction="#openRekamMedis"/>
                <Button text="🧠 Prediksi ML" styleClass="menu-btn" onAction="#openPrediksi"/>
                
                <Label text="LAPORAN" styleClass="menu-group"/>
                <Button text="📊 Hasil &amp; Riwayat" styleClass="menu-btn" onAction="#openHasilRiwayat"/>
                <Button text="📈 Laporan Klinik" styleClass="menu-btn" onAction="#openLaporan"/>
                
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="🚪 Logout" styleClass="logout-btn"/>
            </VBox>
        </ScrollPane>
    </left>
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
            <VBox spacing="5">
                <Label text="Dashboard" styleClass="dashboard-title"/>
                <Label text="Selamat Datang di Smart Clinic System" styleClass="dashboard-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtCariPasien"
                       promptText="Cari data pasien..."
                       prefWidth="250"
                       styleClass="search-box"
                       onAction="#handleCariPasien"/>
        </HBox>
    </top>
    
    <center>
        <VBox spacing="25">
            <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
            <HBox spacing="20">
                <VBox spacing="10" prefWidth="200" prefHeight="120" styleClass="card-blue">
                    <Label text="👨‍⚕ Total Pasien" styleClass="card-title"/>
                    <Label fx:id="lblTotalPasien" text="0" styleClass="card-value"/>
                </VBox>
                <VBox spacing="10" prefWidth="200" prefHeight="120" styleClass="card-green">
                    <Label text="🩺 Total Dokter" styleClass="card-title"/>
                    <Label fx:id="lblTotalDokter" text="0" styleClass="card-value"/>
                </VBox>
                <VBox spacing="10" prefWidth="200" prefHeight="120" styleClass="card-orange">
                    <Label text="💊 Total Obat" styleClass="card-title"/>
                    <Label fx:id="lblTotalObat" text="0" styleClass="card-value"/>
                </VBox>
                <VBox spacing="10" prefWidth="200" prefHeight="120" styleClass="card-red">
                    <Label text="📝 Pendaftaran" styleClass="card-title"/>
                    <Label fx:id="lblTotalPendaftaran" text="0" styleClass="card-value"/>
                </VBox>
                <VBox spacing="10" prefWidth="200" prefHeight="120" styleClass="card-blue">
                    <Label text="📋 Rekam Medis" styleClass="card-title"/>
                    <Label fx:id="lblTotalRekamMedis" text="0" styleClass="card-value"/>
                </VBox>
                <VBox spacing="10" prefWidth="200" prefHeight="120" styleClass="card-orange">
                    <Label text="🧠 Prediksi" styleClass="card-title"/>
                    <Label fx:id="lblTotalPrediksi" text="0" styleClass="card-value"/>
                </VBox>
            </HBox>
            <VBox spacing="15" styleClass="table-container" VBox.vgrow="ALWAYS">
                <Label text="Data Pasien Terbaru" styleClass="section-title"/>
                <TableView fx:id="tableDashboard" prefHeight="400" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colNama" text="Nama" prefWidth="180"/>
                        <TableColumn fx:id="colUmur" text="Umur" prefWidth="80"/>
                        <TableColumn fx:id="colGender" text="Gender" prefWidth="120"/>
                        <TableColumn fx:id="colAlamat" text="Alamat" prefWidth="250"/>
                        <TableColumn fx:id="colAksi" text="Aksi" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>