<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.FormPemeriksaanController" stylesheets="@style.css">
<top><VBox alignment="CENTER" spacing="15" styleClass="top-panel"><Label text="FORM PEMERIKSAAN PASIEN" styleClass="title"/></VBox></top>
<center>
    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 30 50 50 50;">
        <VBox alignment="CENTER" spacing="25">
            <GridPane alignment="CENTER" hgap="20" vgap="15">
                <columnConstraints><ColumnConstraints minWidth="120"/><ColumnConstraints minWidth="220"/></columnConstraints>
                <Label text="Pasien"/><ComboBox fx:id="cbPasien" prefWidth="220" GridPane.columnIndex="1"/>
                <Label text="Dokter" GridPane.rowIndex="1"/><ComboBox fx:id="cbDokter" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Tanggal" GridPane.rowIndex="2"/><DatePicker fx:id="dpTanggal" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label text="Tekanan Darah" GridPane.rowIndex="3"/><TextField fx:id="txtTensi" promptText="120/80" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label text="Suhu Tubuh (°C)" GridPane.rowIndex="4"/><TextField fx:id="txtSuhu" promptText="36.5" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <Label text="Berat Badan (kg)" GridPane.rowIndex="5"/><TextField fx:id="txtBB" promptText="65" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                <Label text="Tinggi Badan (cm)" GridPane.rowIndex="6"/><TextField fx:id="txtTB" promptText="170" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                <Label text="Catatan" GridPane.rowIndex="7"/><TextArea fx:id="txtCatatan" prefWidth="220" prefHeight="60" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
            </GridPane>
            <HBox alignment="CENTER" spacing="20">
                <Button text="💾 Simpan" onAction="#handleSimpan" styleClass="btn-save" prefHeight="40"/>
                <Button text="✖ Batal" onAction="#handleBatal" styleClass="btn-cancel" prefHeight="40"/>
            </HBox>
        </VBox>
    </ScrollPane>
</center>
</BorderPane>