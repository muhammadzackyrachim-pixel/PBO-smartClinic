<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.RekamMedisController"
            stylesheets="@style.css">
    <top>
        <VBox spacing="10" styleClass="top-panel">
            <Label text="DATA REKAM MEDIS"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>
            <HBox spacing="10" alignment="CENTER">
                <Button text="➕ Tambah"
                        onAction="#handleTambah"
                        styleClass="btn-tambah"/>
                <Button text="🔄 Refresh"
                        onAction="#loadData"
                        styleClass="btn-refresh"/>
                <Button text="⬅️ Kembali"
                        onAction="#handleBack"
                        styleClass="btn-close"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="15" styleClass="main-panel" VBox.vgrow="ALWAYS">
            <TableView fx:id="tableRekamMedis"
                       VBox.vgrow="ALWAYS"
                       maxWidth="Infinity">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colPasien" text="Pasien" prefWidth="200"/>
                    <TableColumn fx:id="colDokter" text="Dokter" prefWidth="200"/>
                    <TableColumn fx:id="colTanggal" text="Tanggal" prefWidth="120"/>
                    <TableColumn fx:id="colDiagnosis" text="Diagnosis" prefWidth="250"/>
                    <TableColumn fx:id="colTindakan" text="Tindakan" prefWidth="200"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>
</BorderPane>