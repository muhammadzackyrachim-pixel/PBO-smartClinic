<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.HasilRiwayatController"
            stylesheets="@style.css">
    <top>
        <VBox spacing="10" styleClass="top-panel">
            <Label text="HASIL &amp; RIWAYAT PREDIKSI"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>
            <HBox spacing="15" alignment="CENTER">
                <TextField fx:id="txtCari" promptText="🔍 Cari nama pasien..." prefWidth="250" styleClass="text-field"/>
                <DatePicker fx:id="dpTanggal" promptText="📅 Filter Tanggal" prefWidth="180"/>
                <ComboBox fx:id="cbHasil" promptText="Semua Hasil" prefWidth="200"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="15" styleClass="main-panel" VBox.vgrow="ALWAYS">
            <TableView fx:id="tablePrediksi"
                       VBox.vgrow="ALWAYS"
                       maxWidth="Infinity">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colPasien" text="Pasien" prefWidth="200"/>
                    <TableColumn fx:id="colTanggal" text="Tanggal" prefWidth="150"/>
                    <TableColumn fx:id="colHasil" text="Hasil" prefWidth="250"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>
</BorderPane>