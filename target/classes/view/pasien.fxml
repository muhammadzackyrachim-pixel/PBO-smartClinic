<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PasienController"
            stylesheets="@style.css">

    <!-- TOP-->
    <top>
        <VBox spacing="10" styleClass="top-panel">
            <Label text="DATA PASIEN"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>

            <!-- TOOLBAR DENGAN TOMBOL BERTEKS -->
<HBox fx:id="hboxTombol" spacing="10" alignment="CENTER">
    <Button fx:id="btnTambah" text="➕ Tambah"
            onAction="#handleTambah"
            styleClass="btn-tambah"/>
    
    <Button fx:id="btnEdit" text="✏️ Edit"
            onAction="#handleEdit"
            styleClass="btn-edit"/>
    
    <Button fx:id="btnHapus" text="🗑️ Hapus"
            onAction="#handleHapus"
            styleClass="btn-hapus"/>
    
    
    <TextField fx:id="txtCari"
               promptText="Cari pasien..."
               HBox.hgrow="ALWAYS"
               prefWidth="200"/>
    
</HBox>
        </VBox>
    </top>

    <!-- CENTER DENGAN TABEL FULL WIDTH -->
    <center>
        <VBox spacing="15" 
              styleClass="main-panel"
              VBox.vgrow="ALWAYS"
              maxWidth="Infinity">
            
            <TableView fx:id="tablePasien"
                       VBox.vgrow="ALWAYS"
                       maxWidth="Infinity"
                       prefWidth="Infinity">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colNama" text="Nama" prefWidth="150"/>
                    <TableColumn fx:id="colTanggalLahir" text="Tanggal Lahir" prefWidth="120"/>
                    <TableColumn fx:id="colUmur" text="Umur" prefWidth="80"/>
                    <TableColumn fx:id="colGender" text="Gender" prefWidth="100"/>
                    <TableColumn fx:id="colAlamat" text="Alamat" prefWidth="200"/>
                    <TableColumn fx:id="colHP" text="No HP" prefWidth="130"/>
                    <TableColumn fx:id="colGula" text="Gula Darah" prefWidth="100"/>
                    <TableColumn fx:id="colTekanan" text="Tekanan Darah" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>
</BorderPane>