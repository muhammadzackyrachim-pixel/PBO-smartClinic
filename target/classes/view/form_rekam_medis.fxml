<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.FormRekamMedisController" stylesheets="@style.css">
    <top>
        <VBox alignment="CENTER" spacing="15" styleClass="top-panel">
            <padding><Insets top="20" right="20" bottom="10" left="20"/></padding>
            <Label text="FORM REKAM MEDIS" styleClass="title"/>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="25">
            <padding><Insets top="10" right="30" bottom="20" left="30"/></padding>
            <GridPane alignment="CENTER" hgap="20" vgap="18">
                <columnConstraints>
                    <ColumnConstraints minWidth="120"/>
                    <ColumnConstraints minWidth="220"/>
                </columnConstraints>
                <Label text="Pasien"/><ComboBox fx:id="cbPasien" prefWidth="220" GridPane.columnIndex="1"/>
                <Label text="Dokter" GridPane.rowIndex="1"/><ComboBox fx:id="cbDokter" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Tanggal" GridPane.rowIndex="2"/><DatePicker fx:id="dpTanggal" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label text="Diagnosis" GridPane.rowIndex="3"/><TextArea fx:id="txtDiagnosis" prefWidth="220" prefHeight="60" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label text="Tindakan" GridPane.rowIndex="4"/><TextArea fx:id="txtTindakan" prefWidth="220" prefHeight="60" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <Label text="Catatan" GridPane.rowIndex="5"/><TextArea fx:id="txtCatatan" prefWidth="220" prefHeight="60" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
            </GridPane>
            <HBox alignment="CENTER" spacing="20">
                <Button text="💾 Simpan" onAction="#handleSimpan" styleClass="btn-save" prefWidth="120" prefHeight="40"/>
                <Button text="✖ Batal" onAction="#handleBatal" styleClass="btn-cancel" prefWidth="120" prefHeight="40"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>