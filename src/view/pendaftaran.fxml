<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PendaftaranController"
            stylesheets="@style.css">
    <top>
        <VBox spacing="10" styleClass="top-panel">
            <Label text="DATA PENDAFTARAN"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>
            <HBox fx:id="hboxTombol" spacing="10" alignment="CENTER">
                <Button fx:id="btnTambah" text="➕ Tambah"
                        onAction="#handleTambah"
                        styleClass="btn-tambah"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch" 
                           promptText="🔍 Ketik nama pasien atau keluhan..." 
                           styleClass="text-field" 
                           prefWidth="350"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="15" styleClass="main-panel" VBox.vgrow="ALWAYS">
            <TableView fx:id="tablePendaftaran"
                       VBox.vgrow="ALWAYS"
                       maxWidth="Infinity">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colPasien" text="Pasien" prefWidth="200"/>
                    <TableColumn fx:id="colDokter" text="Dokter" prefWidth="200"/>
                    <TableColumn fx:id="colTanggal" text="Tanggal" prefWidth="120"/>
                    <TableColumn fx:id="colKeluhan" text="Keluhan" prefWidth="250"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER" spacing="15" prefHeight="50">
                <Button fx:id="btnPrev" text="◀ Sebelumnya" onAction="#handlePrevPage" style="-fx-background-color: white; -fx-text-fill: #334155; -fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;"/>
                <Label fx:id="lblHalaman" text="Halaman 1 / 1" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #334155;"/>
                <Button fx:id="btnNext" text="Selanjutnya ▶" onAction="#handleNextPage" style="-fx-background-color: white; -fx-text-fill: #334155; -fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>