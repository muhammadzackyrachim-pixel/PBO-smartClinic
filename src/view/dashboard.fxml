<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainPane" xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DashboardController"
            stylesheets="@style.css"
            styleClass="root-dashboard">
    <left>
        <ScrollPane fx:id="sidebarContainer" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
            <VBox spacing="5" alignment="TOP_CENTER" prefWidth="240" styleClass="sidebar">
                <Label text="SMART CLINIC" styleClass="logo-title"/>
                <Label fx:id="lblCurrentUser" text="Login sebagai: -" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-padding: 0 0 10 0;"/>
                <Separator prefWidth="180"/>
                <Button fx:id="btnDashboard" text="🏠 Dashboard" styleClass="menu-btn, active-menu-btn" onAction="#openDashboard"/>
                <Label fx:id="lblMasterData" text="MASTER DATA" styleClass="menu-group"/>
                <Button fx:id="btnPasien" text="👨‍⚕ Pasien" styleClass="menu-btn" onAction="#openPasien"/>
                <Button fx:id="btnDokter" text="🩺 Dokter" styleClass="menu-btn" onAction="#openDokter"/>
                <Button fx:id="btnPetugas" text="👩‍💼 Petugas" styleClass="menu-btn" onAction="#openPetugas"/>
                <Button fx:id="btnObat" text="💊 Obat" styleClass="menu-btn" onAction="#openObat"/>
                <Button fx:id="btnPoli" text="🏥 Poli" styleClass="menu-btn" onAction="#openPoli"/>
                
                <Label fx:id="lblTransaksi" text="TRANSAKSI" styleClass="menu-group"/>
                <Button fx:id="btnPendaftaran" text="📝 Pendaftaran" styleClass="menu-btn" onAction="#openPendaftaran"/>
                
                <!-- ✅ MENU BARU: PEMERIKSAAN DOKTER -->
                <Button fx:id="btnPemeriksaan" text="🩺 Pemeriksaan Dokter" styleClass="menu-btn" onAction="#openPemeriksaan"/>
                
                <!-- ✅ MENU BARU: RIWAYAT PEMERIKSAAN -->
                <Button fx:id="btnRiwayatPemeriksaan" text="📜 Riwayat Periksa" styleClass="menu-btn" onAction="#openRiwayatPemeriksaan"/>
                
                <Button fx:id="btnRekamMedis" text="🩻 Rekam Medis" styleClass="menu-btn" onAction="#openRekamMedis"/>
                <Button fx:id="btnPrediksi" text="🧠 Prediksi ML" styleClass="menu-btn" onAction="#openPrediksi" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-color: #6366f1; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 10, 0, 0, 4);"/>
                
                <Label fx:id="lblLaporan" text="LAPORAN" styleClass="menu-group"/>
                <Button fx:id="btnHasilRiwayat" text="📊 Hasil &amp; Riwayat" styleClass="menu-btn" onAction="#openHasilRiwayat"/>
                <Button fx:id="btnLaporan" text="📈 Laporan Klinik" styleClass="menu-btn" onAction="#openLaporan"/>
                
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="🚪 Logout" styleClass="logout-btn" onAction="#handleLogout"/>
            </VBox>
        </ScrollPane>
    </left>
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
            <Button text="☰" onAction="#toggleSidebar" style="-fx-background-color: transparent; -fx-font-size: 24px; -fx-cursor: hand; -fx-text-fill: #0f172a;"/>
            <VBox spacing="5">
                <Label text="Dashboard" styleClass="dashboard-title"/>
                <Label text="Selamat Datang di Smart Clinic System" styleClass="dashboard-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtCariPasien"
                       promptText="Cari data pasien..."
                       prefWidth="250"
                       styleClass="search-box"
                       onAction="#handleCariPasien"/>
        </HBox>
    </top>
    
    <center>
        <VBox spacing="25">
            <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
            <HBox spacing="20">
                <VBox fx:id="cardPasien" spacing="10" minWidth="70" prefWidth="200" prefHeight="120" styleClass="card-blue">
                    <Label fx:id="lblTitlePasien" text="👨‍⚕ Total Pasien" styleClass="card-title"/>
                    <Label fx:id="lblTotalPasien" text="0" styleClass="card-value"/>
                </VBox>
                <VBox fx:id="cardDokter" spacing="10" minWidth="70" prefWidth="200" prefHeight="120" styleClass="card-green">
                    <Label fx:id="lblTitleDokter" text="🩺 Total Dokter" styleClass="card-title"/>
                    <Label fx:id="lblTotalDokter" text="0" styleClass="card-value"/>
                </VBox>
                <VBox fx:id="cardObat" spacing="10" minWidth="70" prefWidth="200" prefHeight="120" styleClass="card-orange">
                    <Label fx:id="lblTitleObat" text="💊 Total Obat" styleClass="card-title"/>
                    <Label fx:id="lblTotalObat" text="0" styleClass="card-value"/>
                </VBox>
                <VBox fx:id="cardPendaftaran" spacing="10" minWidth="70" prefWidth="200" prefHeight="120" styleClass="card-red">
                    <Label fx:id="lblTitlePendaftaran" text="📝 Pendaftaran" styleClass="card-title"/>
                    <Label fx:id="lblTotalPendaftaran" text="0" styleClass="card-value"/>
                </VBox>
                <VBox fx:id="cardRekamMedis" spacing="10" minWidth="70" prefWidth="200" prefHeight="120" styleClass="card-blue">
                    <Label fx:id="lblTitleRekamMedis" text="📋 Rekam Medis" styleClass="card-title"/>
                    <Label fx:id="lblTotalRekamMedis" text="0" styleClass="card-value"/>
                </VBox>
                <VBox fx:id="cardPrediksi" spacing="10" minWidth="70" prefWidth="200" prefHeight="120" styleClass="card-orange">
                    <Label fx:id="lblTitlePrediksi" text="🧠 Prediksi" styleClass="card-title"/>
                    <Label fx:id="lblTotalPrediksi" text="0" styleClass="card-value"/>
                </VBox>
            </HBox>
            <VBox spacing="15" styleClass="table-container" VBox.vgrow="ALWAYS">
                <Label text="Antrean Hari Ini" styleClass="section-title"/>
                <TableView fx:id="tableDashboard" prefHeight="400" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID Daftar" prefWidth="80"/>
                        <TableColumn fx:id="colNama" text="Nama Pasien" prefWidth="180"/>
                        <TableColumn fx:id="colWaktu" text="Waktu" prefWidth="100"/>
                        <TableColumn fx:id="colPoli" text="Dokter / Poli" prefWidth="180"/>
                        <TableColumn fx:id="colKeluhan" text="Keluhan" prefWidth="250"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>