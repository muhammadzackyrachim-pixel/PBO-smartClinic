<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.FormDokterController" stylesheets="@style.css">
    <top>
        <VBox alignment="CENTER" spacing="15" styleClass="top-panel">
            <padding><Insets top="20" right="20" bottom="10" left="20"/></padding>
            <Label text="FORM DATA DOKTER" styleClass="title"/>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 30 50 50 50;">
            <VBox alignment="CENTER" spacing="25">
            <padding><Insets top="10" right="30" bottom="20" left="30"/></padding>
            <GridPane alignment="CENTER" hgap="20" vgap="18">
                <columnConstraints>
                    <ColumnConstraints minWidth="120"/>
                    <ColumnConstraints minWidth="220"/>
                </columnConstraints>
                <Label text="ID"/><TextField fx:id="txtId" editable="false" prefWidth="220" GridPane.columnIndex="1"/>
                <Label text="Nama" GridPane.rowIndex="1"/><TextField fx:id="txtNama" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Spesialisasi (Poli)" GridPane.rowIndex="2"/><ComboBox fx:id="cbSpesialisasi" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label text="No HP" GridPane.rowIndex="3"/><TextField fx:id="txtNoHP" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label text="Email" GridPane.rowIndex="4"/><TextField fx:id="txtEmail" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            </GridPane>
            <HBox alignment="CENTER" spacing="20">
                <Button text="💾 Simpan" onAction="#handleSimpan" styleClass="btn-save" prefHeight="40"/>
                <Button text="✖ Batal" onAction="#handleBatal" styleClass="btn-cancel" prefHeight="40"/>
            </HBox>
        </VBox>
        </ScrollPane>
    </center>
</BorderPane>