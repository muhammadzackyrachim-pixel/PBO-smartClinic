<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DokterController"
            stylesheets="@style.css">
    <top>
        <VBox spacing="10" styleClass="top-panel">
            <Label text="DATA DOKTER"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"/>
            <HBox spacing="10" alignment="CENTER">
                <Button text="➕ Tambah"
                        onAction="#handleTambah"
                        styleClass="btn-tambah"/>
                <Button text="✏️ Edit"
                        onAction="#handleEdit"
                        styleClass="btn-edit"/>
                <Button text="🗑️ Hapus"
                        onAction="#handleHapus"
                        styleClass="btn-hapus"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="15" styleClass="main-panel" VBox.vgrow="ALWAYS">
            <TableView fx:id="tableDokter"
                       VBox.vgrow="ALWAYS"
                       maxWidth="Infinity">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colNama" text="Nama" prefWidth="200"/>
                    <TableColumn fx:id="colSpesialisasi" text="Spesialisasi" prefWidth="150"/>
                    <TableColumn fx:id="colHP" text="No HP" prefWidth="150"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>
</BorderPane>